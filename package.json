{
  "name": "hashrate-autopilot",
  "version": "0.1.0",
  "description": "StartOS packaging workspace for Hashrate Autopilot, an operator-run Braiins Hashpower controller and Ocean/Datum mining dashboard.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdubore/hashrate9.git"
  },
  "bugs": {
    "url": "https://github.com/mdubore/hashrate9/issues"
  },
  "homepage": "https://github.com/mdubore/hashrate9#readme",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:workspace-libs": "pnpm --filter @hashrate-autopilot/shared --filter @hashrate-autopilot/bitcoind-client --filter @hashrate-autopilot/braiins-client run build",
    "build:startos": "rm -rf ./javascript && ncc build startos/index.ts -o ./javascript && node -e \"require('fs').writeFileSync('javascript/package.json', '{\\\"type\\\":\\\"commonjs\\\"}\\n')\"",
    "prepare:checks": "pnpm run build:workspace-libs && pnpm --filter @hashrate-autopilot/dashboard run lingui:compile",
    "typecheck": "pnpm run prepare:checks && pnpm -r run typecheck",
    "test": "pnpm run prepare:checks && vitest run",
    "test:watch": "vitest",
    "check": "pnpm -w run lint && pnpm -w run typecheck && pnpm -w run test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release:preflight": "./scripts/release-github.sh preflight",
    "release:artifacts": "./scripts/release-github.sh build",
    "release:checksums": "./scripts/release-github.sh checksums",
    "release:dry-run": "./scripts/release-github.sh dry-run",
    "release:github": "./scripts/release-github.sh release",
    "smoke": "tsx scripts/smoke-braiins.ts",
    "setup": "tsx scripts/setup.ts",
    "daemon": "tsx packages/daemon/src/main.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hashrate-autopilot/braiins-client": "workspace:*",
    "@hashrate-autopilot/daemon": "workspace:*",
    "@hashrate-autopilot/shared": "workspace:*",
    "@inquirer/prompts": "^8.5.2",
    "@start9labs/start-sdk": "0.4.0-beta.62",
    "@types/node": "^25.9.2",
    "@vercel/ncc": "0.38.4",
    "eslint": "^10.4.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "fast-uri": ">=3.1.2"
    }
  }
}
