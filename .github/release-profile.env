# GitHub Release profile for the publishing-github-releases Codex skill.
# This file is safe to source in Bash. Do not place secrets here.

RELEASE_PROJECT_NAME="Hashrate Autopilot for StartOS"
RELEASE_REPO="mdubore/hashrate9"
RELEASE_TAG_PREFIX="startos-v"
RELEASE_TAG_SUFFIX=""
RELEASE_VERSION_COMMAND="grep -Eo \"appVersion = '[^']+'\" startos/utils.ts | cut -d\\' -f2"
RELEASE_TITLE_TEMPLATE='Hashrate Autopilot for StartOS ${RELEASE_VERSION}'
RELEASE_REQUIRED_COMMANDS="pnpm make start-cli sha256sum"
RELEASE_CHECK_COMMANDS="pnpm install --frozen-lockfile && pnpm run check"
RELEASE_BUILD_COMMANDS="make clean && make x86 && make arm"
RELEASE_ARTIFACT_GLOBS="hashrate-autopilot-9_x86_64.s9pk hashrate-autopilot-9_aarch64.s9pk"
RELEASE_REQUIRE_ALL_ARTIFACTS=true
RELEASE_CHECKSUM_FILE="SHA256SUMS"
RELEASE_NOTES_TEMPLATE=".github/release-notes-template.md"
RELEASE_DRAFT=true
RELEASE_PRERELEASE=false
